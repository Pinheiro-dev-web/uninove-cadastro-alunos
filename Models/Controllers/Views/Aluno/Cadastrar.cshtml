@model CadastroAlunos.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Alunos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Cadastro de Aluno (Model Binding)</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Cadastrar" method="post">
                        
                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label">Nome Completo</label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">E-mail</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RA" class="form-label">RA</label>
                            <input asp-for="RA" class="form-control" />
                            <span asp-validation-for="RA" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Curso" class="form-label">Curso</label>
                            <select asp-for="Curso" class="form-select">
                                <option value="">-- Selecione --</option>
                                <option value="Análise e Desenvolvimento de Sistemas">ADS</option>
                                <option value="Ciência da Computação">Ciência da Computação</option>
                                <option value="Engenharia de Software">Engenharia de Software</option>
                            </select>
                            <span asp-validation-for="Curso" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DataNascimento" class="form-label">Data de Nascimento</label>
                            <input asp-for="DataNascimento" class="form-control" />
                            <span asp-validation-for="DataNascimento" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">Cadastrar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
